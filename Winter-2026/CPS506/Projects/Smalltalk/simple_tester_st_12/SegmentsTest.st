'From Pharo10.0.0 of 1 March 2024 [Build information: Pharo-10.0.0+build.539.sha.28169ae414c78e07602b31545f43061b4fa7a88a (64 Bit)] on 10 February 2026 at 4:14:08.478 pm'!TestCase subclass: #SegmentsTest	instanceVariableNames: 'log'	classVariableNames: ''	package: 'CPS506'!!SegmentsTest methodsFor: 'tests' stamp: 'AU 1/30/2026 11:54'!test_2_medium		| rng n k nlines time |		k := 1.	n := 0.	nlines := 10.	rng := Random seed: 42 + nlines.		log set_medium: 'MEDIUM - 10 LINES:' , String cr.	time := Time microsecondClockValue.	1 to: k do:	[ :i | 		| dirs lines x y dx dy sol result p1 p2 result_string |		dirs  := ''.		lines := OrderedCollection new.		nlines timesRepeat: [ lines add: ((1 to: 10) atRandom: rng). 						  dirs := dirs , ('UDLR' atRandom: rng) asString ].		lines := lines asArray.		x := (-10 to: 10) atRandom: rng. dx := x.		y := (-10 to: 10) atRandom: rng. dy := y.		 			1 to: lines size do: [ :j |	| ch ln |			ch := dirs at: j.	ln := lines at: j.			ch = $U ifTrue: [ dy := dy + ln ]. ch = $D ifTrue: [ dy := dy - ln ].			ch = $R ifTrue: [ dx := dx + ln ]. ch = $L ifTrue: [ dx := dx - ln ].		].					p1 := x@y. p2 := dx@dy.			sol := (Segments connect: p1 to: p2 using: lines). 		result := self verify: sol connects: p1 to: p2 using: lines. 		result_string := '  Test ' , i asString , ': ' , p1 asString , ', ' , p2 asString , ', ' , lines asString , String cr.		result_string := result_string , '    You returned ' , sol asString , String cr.		result_string := result_string , '    ' , result asString , String cr.		log set_medium: (log get_medium , result_string ).			result = 'PASSED!!' ifTrue: [ n := n + 1. ].		"self assert: (result = 'PASSED!!')."		"Transcript show: result_string; cr."					].	time := Time microsecondClockValue - time // 1000.	log set_medium: (log get_medium , '  PASSED ' , n asString , '/' , k asString , ' in ' , time asString , 'ms' , String cr ).		"passed n out of k tests in time ms"	^ true			! !!Se