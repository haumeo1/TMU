	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#isMeta : false,
				#className : #SegmentsTest
			},
			#name : #test_2_medium,
			#protocol : #tests,
			#sourceCode : 'test_2_medium\r\t\r\t| rng n k nlines time |\r\t\r\tk := 1.\r\tn := 0.\r\tnlines := 10.\r\trng := Random seed: 42 + nlines.\r\t\r\tlog set_medium: \'MEDIUM - 10 LINES:\' , String cr.\r\ttime := Time microsecondClockValue.\r\t1 to: k do:\t[ :i | \r\t\t| dirs lines x y dx dy sol result p1 p2 result_string |\r\t\tdirs  := \'\'.\r\t\tlines := OrderedCollection new.\r\t\tnlines timesRepeat: [ lines add: ((1 to: 10) atRandom: rng). \r\t\t\t\t\t\t  dirs := dirs , (\'UDLR\' atRandom: rng) asString ].\r\t\tlines := lines asArray.\r\t\tx := (-10 to: 10) atRandom: rng. dx := x.\r\t\ty := (-10 to: 10) atRandom: rng. dy := y.\r\t\t \t\r\t\t1 to: lines size do: [ :j |\t| ch ln |\r\t\t\tch := dirs at: j.\tln := lines at: j.\r\t\t\tch = $U ifTrue: [ dy := dy + ln ]. ch = $D ifTrue: [ dy := dy - ln ].\r\t\t\tch = $R ifTrue: [ dx := dx + ln ]. ch = $L ifTrue: [ dx := dx - ln ].\r\t\t].\t\r\t\t\r\t\tp1 := x@y. p2 := dx@dy.\r\t\r\t\tsol := (Segments connect: p1 to: p2 using: lines). \r\t\tresult := self verify: sol connects: p1 to: p2 using: lines. \r\t\tresult_string := \'  Test \' , i asString , \': \' , p1 asString , \', \' , p2 asString , \', \' , lines asString , String cr.\r\t\tresult_string := result_string , \'    You returned \' , sol asString , String cr.\r\t\tresult_string := result_string , \'    \' , result asString , String cr.\r\t\tlog set_medium: (log get_medium , result_string ).\r\t\r\t\tresult = \'PASSED!\' ifTrue: [ n := n + 1. ].\r\t\t"self assert: (result = \'PASSED!\')."\r\t\t"Transcript show: result_string; cr."\r\t\t\t\t\r\t].\r\ttime := Time microsecondClockValue - time // 1000.\r\tlog set_medium: (log get_medium , \'  PASSED \' , n asString , \'/\' , k asString , \' in \' , time asString , \'ms\' , String cr ).\r\t\r\t"passed n out of k tests in time ms"\r\t^ true\r\t\r\t\r\t',
			#stamp : 'AU 1/30/2026 11:54',
			#package : #CPS506
		}
	}
}OmEntry {
