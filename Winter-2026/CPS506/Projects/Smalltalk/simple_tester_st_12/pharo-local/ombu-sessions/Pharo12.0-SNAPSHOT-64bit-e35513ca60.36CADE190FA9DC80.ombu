	#tags : {
		#prior : OmReference [ '12' ],
		#self : OmReference [ '13' ]
	},
	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#isMeta : false,
				#className : #SegmentsTest
			},
			#name : #'verify:connects:to:using:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'verify: sol connects: p1 to: p2 using: lines\r\r\t| dx dy |\r\r\t"Check return type"\r\tsol isString ifFalse: [ ^\'FAILED: Return type must be String.\' ].\r\r\t"Check number of characters"\r\tsol size = lines size ifFalse: [ ^\'FAILED: Length of string should match number of lines.\' ]. \r\t\r\t"Check for bad characters"\r\t(sol reject: [ :c | \'UDRL\' includes: c ]) = \'\' ifFalse: [ ^\'FAILED: Solution should only contain U, D, R, L.\' ].\r\t\r\tdx := p1 x.\r\tdy := p1 y.\r\r\t1 to: lines size do: [ :i |\r\t\t| ch ln |\r\t\tch := sol at: i.\r\t\tln := lines at: i.\r\t\tch = $U ifTrue: [ dy := dy + ln ].\r\t\tch = $D ifTrue: [ dy := dy - ln ].\r\t\tch = $R ifTrue: [ dx := dx + ln ].\r\t\tch = $L ifTrue: [ dx := dx - ln ].\r\t].\r\r\t(dx = p2 x) & (dy = p2 y) ifFalse: [ ^\'FAILED: Finish point incorrect\' ]. \r\t\r \t^\'PASSED!\'\r\r\r',
			#stamp : 'AU 1/28/2026 14:31',
			#package : #CPS506
		}
	}
}OmEntry {
