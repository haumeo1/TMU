" 	Execute this code to run the tests. You MUST run the tests using this	playground script. Running the tests from the 	system browser, as you 	did in Lab 2, will not work. "| log t_small t_medium t_large t_mega t_giga |Transcript clear.log := SegmentsLog new.SegmentsTest defaultTimeLimitSecs: 30." Create and run all tests "t_small  := (SegmentsTest selector: #test_1_small).  t_small  setLog: log; run.t_medium := (SegmentsTest selector: #test_2_medium). t_medium setLog: log; run.t_large  := (SegmentsTest selector: #test_3_large).  t_large  setLog: log; run.t_mega   := (SegmentsTest selector: #test_4_mega).   t_mega   setLog: log; run.t_giga   := (SegmentsTest selector: #test_5_giga).   t_giga   setLog: log; run." Print results of all tests "Transcript show: log get_all; cr." Write log to file "'st_log.txt' asFileReference writeStreamDo: [ :stream | stream << log get_all ].