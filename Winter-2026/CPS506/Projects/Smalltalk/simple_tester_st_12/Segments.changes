 p1 to: p2 using: lines). 		result := self verify: sol connects: p1 to: p2 using: lines. 		result_string := '  Test ' , i asString , ': ' , p1 asString , ', ' , p2 asString , ', ' , lines asString , String cr.		result_string := result_string , '    You returned ' , sol asString , String cr.		result_string := result_string , '    ' , result asString , String cr.		log set_medium: (log get_medium , result_string ).			result = 'PASSED!!' ifTrue: [ n := n + 1. ].		"self assert: (result = 'PASSED!!')."		"Transcript show: result_string; cr."					].	time := Time microsecondClockValue - time // 1000.	log set_medium: (log get_medium , '  PASSED ' , n asString , '/' , k asString , ' in ' , time asString , 'ms' , String cr ).		"passed n out of k tests in time ms"	^ true			! !!SegmentsTest methodsFor: 'tests' stamp: 'AU 1/30/2026 11:54'!test_4_mega		| rng n k nlines time |		k := 1.	n := 0.	nlines := 50.	rng := Random seed: 42 + nlines.		log set_mega: 'MEGA - 50 LINES:' , String cr.	time := Time microsecondClockValue.	1 to: k do:	[ :i | 		| dirs lines x y dx dy sol result p1 p2 result_string |		dirs  := ''.		lines := OrderedCollection new.		nlines timesRepeat: [ lines add: ((1 to: 10) atRandom: rng). 						  dirs := dirs , ('UDLR' atRandom: rng) asString ].		lines := lines asArray.		x := (-10 to: 10) atRandom: rng. dx := x.		y := (-10 to: 10) atRandom: rng. dy := y.		 			1 to: lines size do: [ :j |	| ch ln |			ch := dirs at: j.	ln := lines at: j.			ch = $U ifTrue: [ dy := dy + ln ]. ch = $D ifTrue: [ dy := dy - ln ].			ch = $R ifTrue: [ dx := dx + ln ]. ch = $L ifTrue: [ dx := dx - ln ].		].					p1 := x@y. p2 := dx@dy.			sol := (Segments connect: p1 to: p2 using: lines). 		result := self verify: sol connects: p1 to: p2 using: lines. 		result_string := '  Test ' , i asString , ': ' , p1 asString , ', ' , p2 asString , ', ' , lines asString , String cr.		result_string := result_string , '    You returned ' , sol asString , String cr.		result_string := result_string , '    ' , result asString , String cr.		log set_mega: (log get_mega , result_string ).			result = 'PASSED!!' ifTrue: [ n := n + 1. ].		"self assert: (result = 'PASSED!!')."		"Transcript show: result_string; cr."					].	time := Time microsecondClockValue - time // 1000.	log set_mega: (log get_mega , '  PASSED ' , n asString , '/' , k asString , ' in ' , time asString , 'ms' , String cr ).		^ true			! !!SegmentsTest methodsFor: 'tests' stamp: 'AU 1/30/2026 11:54'!test_3_large		| rng n k nlines time |		k := 1.	n := 0.	nlines := 20.	rng := Random seed: 42 + nlines.		log set_large: 'LARGE - 20 LINES:' , String cr.	time := Time microsecondClockValue.	1 to: k do:	[ :i | 		| dirs lines x y dx dy sol result p1 p2 result_string |		dirs  := ''.		lines := OrderedCollection new.		nlines timesRepeat: [ lines add: ((1 to: 10) atRandom: rng). 						  dirs := dirs , ('UDLR' atRandom: rng) asString ].		lines := lines asArray.		x := (-10 to: 10) atRandom: rng. dx := x.		y := (-10 to: 10) atRandom: rng. dy := y.		 			1 to: lines size do: [ :j |	| ch ln |			ch := dirs at: j.	ln := lines at: j.			ch = $U ifTrue: [ dy := dy + ln ]. ch = $D ifTrue: [ dy := dy - ln ].			ch = $R ifTrue: [ dx := dx + ln ]. ch = $L ifTrue: [ dx := dx - ln ].		].					p1 := x@y. p2 := dx@dy.			sol := (Segments connect: p1 to: p2 using: lines). 		result := self verify: sol connects: p1 to: p2 using: lines. 		result_string := '  Test ' , i asString , ': ' , p1 asString , ', ' , p2 asString , ', ' , lines asString , String cr.		result_string := result_string , '    You returned ' , sol asString , String cr.		result_string := result_string , '    ' , result asString , String cr.		log set_large: (log get_large , result_string ).			result = 'PASSED!!' ifTrue: [ n := n + 1. ].		"self assert: (result = 'PASSED!!')."		"Transcript show: result_string; cr."					].	time := Time microsecondClockValue - time // 1000.	log set_large: (log get_large , '  PASSED ' , n asString , '/' , k asString , ' in ' , time asString , 'ms' , String cr ).		^ true			! !!SegmentsTest methodsFor: 'tests' stamp: 'AU 1/30/2026 11:54'!test_1_small		| rng n k nlines time |		k := 1.	n := 0.	nlines := 5.	rng := Random seed: 42 + nlines.		log set_small: 'SMALL - 5 LINES:' , String cr.	time := Time microsecondClockValue.	1 to: k do:	[ :i | 		| dirs lines x y dx dy sol result p1 p2 result_string |		dirs  := ''.		lines := OrderedCollection new.		nlines timesRepeat: [ lines add: ((1 to: 10) atRandom: rng). 						  dirs := dirs , ('UDLR' atRandom: rng) asString ].		lines := lines asArray.		x := (-10 to: 10) atRandom: rng. dx := x.		y := (-10 to: 10) atRandom: rng. dy := y.		 			1 to: lines size do: [ :j |	| ch ln |			ch := dirs at: j.	ln := lines at: j.			ch = $U ifTrue: [ dy := dy + ln ]. ch = $D ifTrue: [ dy := dy - ln ].			ch = $R ifTrue: [ dx := dx + ln ]. ch = $L ifTrue: [ dx := dx - ln ].		].					p1 := x@y. p2 := dx@dy.			sol := (Segments connect: p1 to: p2 using: lines). 		result := self verify: sol connects: p1 to: p2 using: lines. 		result_string := '  Test ' , i asString , ': ' , p1 asString , ', ' , p2 asString , ', ' , lines asString , String cr.		result_string := result_string , '    You returned ' , sol asString , String cr.		result_string := result_string , '    ' , result asString , String cr.		log set_small: (log get_small , result_string ).			result = 'PASSED!!' ifTrue: [ n := n + 1. ].		"self assert: (result = 'PASSED!!')."		"Transcript show: result_string; cr."					].	time := Time microsecondClockValue - time // 1000.	log set_small: (log get_small , '  PASSED ' , n asString , '/' , k asString , ' in ' , time asString , 'ms' , String cr ).		"passed n out of k tests in time ms"	^ true			! !!SegmentsTest methodsFor: 'tests' stamp: 'AU 1/30/2026 11:54'!test_5_giga		| rng n k nlines time |		k := 1.	n := 0.	nlines := 100.	rng := Random seed: 42 + nlines.		log set_giga: 'GIGA - 100 LINES:' , String cr.	time := Time microsecondClockValue.	1 to: k do:	[ :i | 		| dirs lines x y dx dy sol result p1 p2 result_string |		dirs  := ''.		lines := OrderedCollection new.		nlines timesRepeat: [ lines add: ((1 to: 10) atRandom: rng). 						  dirs := dirs , ('UDLR' atRandom: rng) asString ].		lines := lines asArray.		x := (-10 to: 10) atRandom: rng. dx := x.		y := (-10 to: 10) atRandom: rng. dy := y.		 			1 to: lines size do: [ :j |	| ch ln |			ch := dirs at: j.	ln := lines at: j.			ch = $U ifTrue: [ dy := dy + ln ]. ch = $D ifTrue: [ dy := dy - ln ].			ch = $R ifTrue: [ dx := dx + ln ]. ch = $L ifTrue: [ dx := dx - ln ].		].					p1 := x@y. p2 := dx@dy.			sol := (Segments connect: p1 to: p2 using: lines). 		result := self verify: sol connects: p1 to: p2 using: lines. 		result_string := '  Test ' , i asString , ': ' , p1 asString , ', ' , p2 asString , ', ' , lines asString , String cr.		result_string := result_string , '    You returned ' , sol asString , String cr.		result_string := result_string , '    ' , result asString , String cr.		log set_giga: (log get_giga , result_string ).			result = 'PASSED!!' ifTrue: [ n := n + 1. ].		"self assert: (result = 'PASSED!!')."		"Transcript show: result_string; cr."					].	time := Time microsecondClockValue - time // 1000.	log set_giga: (log get_giga , '  PASSED ' , n asString , '/' , k asString , ' in ' , time asString , 'ms' , String cr ).		^ true			! !!SegmentsTest methodsFor: 'initialization' stamp: 'AU 1/28/2026 14:36'!setLog: lg	log := lg.! !!SegmentsTest methodsFor: 'as yet unclassified' stamp: 'AU 1/28/2026 14:31'!verify: sol connects: p1 to: p2 using: lines	| dx dy |	"Check return type"	sol isString ifFalse: [ ^'FAILED: Return type must be String.' ].	"Check number of characters"	sol size = lines size ifFalse: [ ^'FAILED: Length of string should match number of lines.' ]. 		"Check for bad characters"	(sol reject: [ :c | 'UDRL' includes: c ]) = '' ifFalse: [ ^'FAILED: Solution should only contain U, D, R, L.' ].		dx := p1 x.	dy := p1 y.	1 to: lines size do: [ :i |		| ch ln |		ch := sol at: i.		ln := lines at: i.		ch = $U ifTrue: [ dy := dy + ln ].		ch = $D ifTrue: [ dy := dy - ln ].		ch = $R ifTrue: [ dx := dx + ln ].		ch = $L ifTrue: [ dx := dx - ln ].	].	(dx = p2 x) & (dy = p2 y) ifFalse: [ ^'FAILED: Finish point incorrect' ]. 	 	^'PASSED!!'! !----End fileIn----!'From Pharo10.0.0 of 1 March 2024 [Build information: Pharo-10.0.0+build.539.sha.28169ae414c78e07602b31545f43061b4fa7a88a (64 Bit)] on 10 February 2026 at 4:14:05.04 pm'!!SegmentsLog methodsFor: 'initialization' stamp: 'AU 1/30/2026 11:40'!get_medium	^res_medium! !!SegmentsLog methodsFor: 'initialization' stamp: 'AU 1/28/2026 14:33'!get_mega	^res_mega! !!SegmentsLog methodsFor: 'initialization' stamp: 'AU 1/28/2026 14:32'!set_small: result	res_small := result! !!SegmentsLog methodsFor: 'initialization' stamp: 'AU 1/28/2026 14:33'!get_small	^res_small! !!SegmentsLog methodsFor: 'initialization' stamp: 'AU 1/28/2026 14:32'!set_large: result	res_large := result! !!SegmentsLog methodsFor: 'initialization' stamp: 'AU 1/28/2026 14:34'!get_all   | nl |	nl := String cr.	^ self get_small, nl, self get_medium, nl, self get_large, nl, self get_mega, nl, self get_giga.! !!SegmentsLog methodsFor: 'initialization' stamp: 'AU 1/28/2026 14:32'!set_giga: result	res_giga := result! !!SegmentsLog methodsFor: 'initialization' stamp: 'AU 1/28/2026 14:32'!set_medium: result	res_medium := result! !!SegmentsLog methodsFor: 'initialization' stamp: 'AU 1/28/2026 14:32'!set_mega: result	res_mega := result! !!SegmentsLog methodsFor: 'initialization' stamp: 'AU 1/28/2026 14:33'!get_large	^res_large! !!SegmentsLog methodsFor: 'initialization' stamp: 'AU 1/28/2026 14:32'!get_giga	^res_giga! !----End fileIn----!'From Pharo10.0.0 of 1 March 2024 [Build information: Pharo-10.0.0+build.539.sha.28169ae414c78e07602b31545f43061b4fa7a88a (64 Bit)] on 10 February 2026 at 4:13:58.793 pm'!"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Segments class	instanceVariableNames: ''!!Segments class methodsFor: 'as yet unclassified' stamp: 'AU 1/30/2026 11:19'!connect: start to: end using: lines	" Your code here "	^'URD'! !----End fileIn----!----QUIT----2026-02-10T16:38:33.584-05:00 Segments.image priorSource: 496!----QUIT----2026-02-10T16:38:33.601-05:00 Segments.image priorSource: 12362!!Segments class methodsFor: 'as yet unclassified' stamp: '3/2/2026 15:17' prior: 24547!connect: start to: end using: lines		| totalSum memo result |    totalSum := 0.    lines do: [:len | totalSum := totalSum + len ].    memo := Dictionary new.    result := self        dfsFrom: start        to: end        using: lines        index: 1        remainingSum: totalSum        memo: memo.    ^ result ifNil: [''] ifNotNil: [result]! !!Segments class methodsFor: 'nil' stamp: '3/2/2026 15:17'!dfsFrom: current to: end using: lines index: idx remainingSum: rem memo: memo    | n key dist parityOk len remAfter moves sortedMoves |    n := lines size.    "CHeck if at the end"  	idx > n ifTrue:  [ 			^ (current = end) ifTrue: [ ^'' ] ifFalse:[nil] 		 ].	    "Prune by distance vs remaining total length"    dist := (current x - end x) abs + (current y - end y) abs.    dist > rem ifTrue: [ ^ nil ].    "Prune by parity with remaining lengths (necessary condition)"    parityOk := (((current x + current y + rem) \\ 2) = ((end x + end y) \\ 2)).    parityOk ifFalse: [ ^ nil ].    "Check to see whether we have sovlved this case or not"    key := Array with: idx with: current x with: current y.		(memo includesKey: key) ifTrue: [ ^nil ].	len := lines  at: idx.	remAfter := rem - len.    "Generate possible next points for this segment length"    moves := { 		$U -> (current + (0@len)).		$D -> (current + (0@(0-len))).		$L -> (current + ((0-len)@0)).		$R -> (current + (len@0)) }.    	"Try moves that get closer to end first"	sortedMoves := moves asSortedCollection: [ :a :b|			|va vb ra rb |	va := a value.	vb := b value.	ra := (va x - end x) abs + (va y - end y) abs.	rb := (va x - end x) abs + (va y - end y) abs.	ra < rb.		 ].		sortedMoves do:  [:temp |		|nextP disP nextC suffix|		nextP := temp value.		disP := (nextP x - end x) abs + (nextP y - end y).		disP > remAfter ifFalse: [ 			nextC := (((nextP x + nextP y + remAfter) \\ 2) = ((end x + end y) \\ 2)).            nextC ifTrue: [				suffix := self dfsFrom:nextP  to: end using: lines index: idx + 1 remainingSum: remAfter memo: memo.				suffix ifNotNil: [ ^ (String with: temp key), suffix ].				].			 ].									  ].	       "Mark this state as impossible and backtrack"    memo at: key put: true.    ^ nil! !----SNAPSHOT----2026-03-02T15:46:15.618765-05:00 Segments.image priorSource: 12438!----SNAPSHOT----2026-03-02T15:46:15.621866-05:00 Segments.image priorSource: 14862!